# Copy to .env and fill in. .env is gitignored — never commit secrets.

# v0 uses public endpoints only; no keys required to run.

# BYOK (future, authenticated features only — your own venue keys):
# KALSHI_API_KEY_ID=
# KALSHI_PRIVATE_KEY_PATH=
# POLYMARKET_PRIVATE_KEY=

# Identifiable User-Agent sent with every venue request
TINLI_USER_AGENT=tinli/0.1 (+https://tinli.dev)

# Set to 1 to force demo mode (recorded fixtures, SIMULATED DATA badge)
TINLI_DEMO=0

# Self-reported positions file for /v1/risk (default: data/positions.yaml)
# TINLI_POSITIONS=data/positions.yaml
